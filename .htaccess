RewriteEngine On

# Ensure the default directory index is public/index.php
DirectoryIndex public/index.php

# Disable directory listing for security
Options -Indexes

# Let app routes win over same-name project directories such as /documentation.
DirectorySlash Off

# Support asset URLs with or without the public prefix.
RewriteCond %{DOCUMENT_ROOT}/public/assets/$1 -f
RewriteRule ^assets/(.+)$ public/assets/$1 [QSA,L]

# Route app-owned pretty URLs that collide with real project directories.
RewriteRule ^documentation(?:/.*)?$ public/index.php [QSA,L]
RewriteRule ^docs(?:/.*)?$ public/index.php [QSA,L]

# Exclude static files (CSS, JS, images) from routing to index.php
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule \.(css|js|png|jpg|jpeg|gif|svg|webp)$ - [L]

# Only route non-existent files or directories to public/index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/index.php [QSA,L]

# Error pages
ErrorDocument 404 /notfound
